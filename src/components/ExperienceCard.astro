---
interface Props {
  jobTitle: string;
  company: string;
  dates: string;
  bullets: string[];
  stacked?: boolean;
}
const { jobTitle, company, dates, bullets, stacked = false } = Astro.props;
---

<div class="mb-8 pl-4 border-l-2 border-teal-700 hover:border-teal-500 transition-colors duration-200 relative before:absolute before:-left-[5px] before:top-0 before:w-2 before:h-2 before:rounded-full before:bg-teal-700 hover:before:bg-teal-500">
  {stacked ? (
    <div class="mb-1">
      <span class="font-semibold text-lg block">{jobTitle}</span>
      <div class="flex flex-wrap items-baseline justify-between gap-2 mt-0.5">
        <span class="text-teal-300 text-sm">{company}</span>
        <span class="text-sm text-zinc-400 shrink-0">{dates}</span>
      </div>
    </div>
  ) : (
    <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
      <div>
        <span class="font-semibold text-lg">{jobTitle}</span>
        <span class="text-zinc-400 mx-2">·</span>
        <span class="text-teal-300">{company}</span>
      </div>
      <span class="text-sm text-zinc-400 shrink-0">{dates}</span>
    </div>
  )}
  <ul class="mt-2 space-y-1">
    {bullets.map((b) => (
      <li class="text-zinc-200 text-sm leading-6 pl-3 relative before:content-['–'] before:absolute before:left-0 before:text-zinc-500">
        {b}
      </li>
    ))}
  </ul>
</div>
