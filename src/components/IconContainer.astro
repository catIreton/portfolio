---
interface Props {
  name: string;
}
const { name } = Astro.props;
---

<div class="flex flex-col items-center justify-center">
  <div
    class="inline-flex flex-col items-center justify-center p-3 border rounded-md bg-zinc-800 border-zinc-600 transition-all duration-150 hover:bg-zinc-700 hover:border-zinc-500 hover:-translate-y-0.5"
  >
    <slot />
  </div>
  <span class="text-zinc-200 text-sm mt-1">{name}</span>
</div>
