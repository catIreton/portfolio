---
interface Props {
  name: string;
  image: string;
}
const { name, image } = Astro.props;
---

<div class="flex flex-col items-center justify-center">
  <div
    class="inline-flex flex-col items-center justify-center p-3 border rounded-md bg-zinc-800 border-zinc-600"
  >
    <img
      class="w-24 h-24 object-contain rounded"
      src={image}
      alt={name}
      loading="lazy"
    />
  </div>
  <span class="text-zinc-200 text-sm mt-1">{name}</span>
</div>
