---
import ProjectCard from "@components/ProjectCard.astro";
---

<section class="my-14">
  <h2 class="text-2xl font-semibold mb-2">Projects</h2>
  <div class="mb-6 h-px bg-gradient-to-r from-zinc-600 to-transparent"></div>

  <ProjectCard
    projectTitle="Stay Tuned"
    projectDescription="A retro CRT-aesthetic TV show tracker. Search for shows, track episodes, manage viewing status, and add ratings and notes — all with a nostalgic phosphor-green interface."
    projectLink="https://catireton.github.io/stay-tuned/"
    githubLink="https://github.com/catIreton/stay-tuned"
    image="/portfolio/images/stay-tuned.png"
    techs={["Next.js", "TypeScript", "Tailwind CSS", "Zustand", "TanStack Query"]}
  />

  <ProjectCard
    projectTitle="Rules Lawyer"
    projectDescription="Quick reference sheets for board games, actually readable. Search by name, tag, or category to find the rule you need in seconds."
    projectLink="https://catireton.github.io/rules-lawyer/"
    githubLink="https://github.com/catIreton/rules-lawyer"
    image="/portfolio/images/rules-lawyer.png"
    techs={["Next.js", "TypeScript", "Tailwind CSS", "Fuse.js"]}
  />

  <ProjectCard
    projectTitle="On Rewind Video"
    projectDescription="A video rental store simulation game set in the 90s. Help customers find the perfect tape before your shift ends."
    projectLink="https://catireton.github.io/late-fee/"
    githubLink="https://github.com/catIreton/late-fee"
    image="/portfolio/images/late-fee.png"
    techs={["TypeScript", "Phaser 3", "Vite"]}
  />

  <ProjectCard
    projectTitle="Drug Wars Remake"
    projectDescription="Recreation of the 1984 Drug Wars game but set in Kansas City"
    projectLink="https://catireton.github.io/drugwars/"
    githubLink="https://github.com/catIreton/drugwars"
    image="/portfolio/images/og-preview.jpg"
    techs={["React", "JavaScript", "Material UI", "Leaflet"]}
  />

  <ProjectCard
    projectTitle="Portfolio"
    projectDescription="Personal developer portfolio built with Astro and Tailwind CSS"
    projectLink="https://catireton.github.io/portfolio/"
    githubLink="https://github.com/catIreton/portfolio"
    image="/portfolio/images/readme.png"
    techs={["Astro", "TypeScript", "Tailwind CSS"]}
  />
</section>
