---
import ProjectCard from "@components/ProjectCard.astro";
---

<section class="my-14">
  <h2 class="text-2xl font-semibold mb-2">Projects</h2>
  <hr class="mb-6 border-zinc-600" />

  <ProjectCard
    projectTitle="On Rewind Video"
    projectDescription="A video rental store simulation game set in the 90s. Help customers find the perfect tape before your shift ends."
    projectLink="https://catireton.github.io/late-fee/"
    githubLink="https://github.com/catIreton/late-fee"
    image="/portfolio/images/late-fee.png"
    techs={["TypeScript", "Phaser 3", "Vite"]}
  />

  <ProjectCard
    projectTitle="Drug Wars Remake"
    projectDescription="Recreation of the 1984 Drug Wars game but set in Kansas City"
    projectLink="https://catireton.github.io/drugwars/"
    githubLink="https://github.com/catIreton/drugwars"
    image="/portfolio/images/og-preview.jpg"
    techs={["React", "JavaScript", "Material UI", "Leaflet"]}
  />

  <ProjectCard
    projectTitle="Portfolio"
    projectDescription="Personal developer portfolio built with Astro and Tailwind CSS"
    projectLink="https://catireton.github.io/portfolio/"
    githubLink="https://github.com/catIreton/portfolio"
    image="/portfolio/images/readme.png"
    techs={["Astro", "TypeScript", "Tailwind CSS"]}
  />
</section>
