---
import ArrowLink from "@assets/icons/arrow-link.astro";
import Github from "@assets/icons/github.astro";

interface Props {
  projectTitle: string;
  projectDescription: string;
  projectLink: string;
  githubLink?: string;
  image: string;
  techs?: string[];
}
const { projectTitle, projectDescription, projectLink, githubLink, image, techs = [] } = Astro.props;
---

<article
  style={{ backgroundImage: "radial-gradient(circle, #6c6c6c1d 0%, transparent 100%)" }}
  class="border border-zinc-700 bg-zinc-900/40 p-8 rounded-lg flex flex-col-reverse md:flex-row justify-between mb-7 shadow-xl"
>
  <div>
    <h3 class="text-xl font-semibold mb-2">{projectTitle}</h3>
    <p class="text-zinc-200 text-sm text-pretty pr-2 mb-4">{projectDescription}</p>
    <div class="flex items-center gap-4 mb-4">
      <a
        class="inline-flex items-center gap-1.5 text-sm hover:opacity-60 transition-opacity duration-150"
        target="_blank"
        rel="noopener noreferrer"
        href={projectLink}
      >
        Live site <ArrowLink size="w-4 h-4" />
      </a>
      {githubLink && (
        <a
          class="inline-flex items-center gap-1.5 text-sm text-zinc-200 hover:opacity-60 transition-opacity duration-150"
          target="_blank"
          rel="noopener noreferrer"
          href={githubLink}
        >
          GitHub <Github size="w-4 h-4" />
        </a>
      )}
    </div>
    <div class="flex flex-wrap items-center gap-2">
      {techs.map((tech) => (
        <span class="text-xs px-2 py-0.5 rounded border border-zinc-600 text-zinc-400">{tech}</span>
      ))}
    </div>
  </div>
  <img
    class="w-full mb-5 shadow-xl rounded-lg md:w-52 md:mb-0"
    src={image}
    alt={projectTitle}
    loading="lazy"
  />
</article>
