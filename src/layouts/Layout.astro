---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Cat Ireton — Full Stack Software Developer portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/portfolio/icons/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <link rel="canonical" href="https://catireton.github.io/portfolio/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://catireton.github.io/portfolio/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://catireton.github.io/portfolio/images/readme.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://catireton.github.io/portfolio/images/readme.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
